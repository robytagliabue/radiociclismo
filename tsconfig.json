{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist"
  },
  "include": ["src/index.ts", "src/agents/**/*", "src/functions/**/*"],
  "exclude": ["node_modules", "dist", "src/mastra"]
}
